# Safe product settings. These values may be rendered in the UI.
APP_NAME=next-moodle
APP_LOCALE=ja-JP
APP_TIME_ZONE=Asia/Tokyo

# Server-only Moodle integration. Use one trusted Moodle per deployment.
MOODLE_BASE_URL=https://moodle.example.edu
MOODLE_SERVICE=moodle_mobile_app

# Generate a unique 32-byte-or-longer value. Do not reuse this placeholder.
# Example: openssl rand -hex 48
SESSION_PASSWORD=replace-with-a-generated-secret

# Public development instrumentation flag. Set to 1 to profile without overlays.
NEXT_PUBLIC_DISABLE_REACT_DEVTOOLS=0

# Moodle credentials, tokens, cookies, and session secrets never belong in this file.
