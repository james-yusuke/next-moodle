# Safe product settings. These values may be rendered in the UI.
APP_NAME=next-moodle
APP_LOCALE=ja-JP
APP_TIME_ZONE=Asia/Tokyo

# Server-only Moodle integration. Use one trusted Moodle per deployment.
MOODLE_BASE_URL=https://moodle.example
MOODLE_SERVICE=moodle_mobile_app
MOODLE_REQUIRE_COMPANION=true
MOODLE_TEACHER_ROLE_SHORTNAMES=editingteacher,teacher

# Generate a unique 32-byte-or-longer value. Do not reuse this placeholder.
# Example: openssl rand -hex 48
SESSION_PASSWORD=replace-with-a-generated-secret

# Optional server-only AI writing assistance. Disabled unless explicitly enabled.
AI_ASSIST_ENABLED=false
OPENAI_API_KEY=
OPENAI_COMPLETION_MODEL=gpt-5.6-luna
OPENAI_REVIEW_MODEL=gpt-5.6-terra
AI_SAFETY_SECRET=replace-with-an-independent-secret-of-at-least-32-bytes
# Optional link shown in the consent disclosure. HTTPS only.
# AI_PRIVACY_NOTICE_URL=https://privacy.example.edu/ai-assistance

# Public development instrumentation flag. Set to 1 to profile without overlays.
NEXT_PUBLIC_DISABLE_REACT_DEVTOOLS=0

# Moodle credentials, API keys, tokens, cookies, and real secrets never belong in this file.
